  "description": "qproof MCP — post-quantum readiness for AI coding agents via the Model Context Protocol. Zero runtime dependencies (stdio JSON-RPC implemented in-house).",
  "license": "Apache-2.0",
  "type": "module",
  "bin": { "qproof-mcp": "./dist/stdio.js" },
  "main": "./dist/index.js",
