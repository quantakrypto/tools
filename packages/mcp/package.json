      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "HOSTING.md", "examples"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "@qproof/core": "0.1.0"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --import tsx --test test/*.test.ts"
  }
}
